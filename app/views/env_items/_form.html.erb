<%= form_with model: [@app, @app_env, @env_set, @env_item] do |f| %>
  <div class="mb-3">
    <%= f.label :key, class: "form-label" %>
    <%= f.text_field :key, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :value_type, class: "form-label" %>
    <%= f.select :value_type, EnvItem::VALUE_TYPES, {}, class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= f.label :value, class: "form-label" %>
    <%= f.text_area :value, rows: 5, class: "form-control" %>
  </div>

  <div class="form-check mb-3">
    <%= f.check_box :value_present, class: "form-check-input" %>
    <%= f.label :value_present, "Value present (used for secret values)", class: "form-check-label" %>
  </div>

  <%= f.submit class: "btn btn-primary" %>
<% end %>
