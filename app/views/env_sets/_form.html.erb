<%= form_with model: [@app, @app_env, @env_set] do |f| %>
  <div class="mb-3">
    <%= f.label :name, class: "form-label" %>
    <%= f.text_field :name, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :category, class: "form-label" %>
    <%= f.select :category, EnvSet::CATEGORIES, {}, class: "form-select" %>
  </div>

  <div class="form-check mb-3">
    <%= f.check_box :ui_editable, class: "form-check-input" %>
    <%= f.label :ui_editable, "Editable from UI", class: "form-check-label" %>
  </div>

  <%= f.submit class: "btn btn-primary" %>
<% end %>
