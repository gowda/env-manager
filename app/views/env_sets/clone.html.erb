<h1 class="h3 mb-3">Clone Set: <%= @env_set.name %></h1>

<% if @clone_error.present? %>
  <div class="alert alert-danger"><%= @clone_error %></div>
<% end %>

<%= form_with url: clone_app_app_env_env_set_path(@app, @app_env, @env_set), scope: :clone do |f| %>
  <div class="mb-3">
    <%= f.label :clone_name, "Clone name", class: "form-label" %>
    <%= f.text_field :clone_name, value: "Copy of #{@env_set.name}", class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :destination_app_id, "Destination app", class: "form-label" %>
    <%= f.collection_select :destination_app_id, @apps, :id, :name, { selected: @app.id }, class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= f.label :destination_app_env_id, "Destination environment (optional if creating new)", class: "form-label" %>
    <%= f.collection_select :destination_app_env_id, @app.app_envs.order(:name), :id, :name, { include_blank: true }, class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= f.label :destination_new_environment_name, "Or create new destination environment", class: "form-label" %>
    <%= f.text_field :destination_new_environment_name, class: "form-control" %>
  </div>

  <% if @secret_keys.any? %>
    <h2 class="h5 mt-4">Secret values to copy</h2>
    <% @secret_keys.each do |item| %>
      <div class="form-check mb-2">
        <%= check_box_tag "clone[selected_secret_keys][]", item.key, true, id: "clone_selected_secret_keys_#{item.id}", class: "form-check-input" %>
        <%= label_tag "clone_selected_secret_keys_#{item.id}", item.key, class: "form-check-label" %>
      </div>
    <% end %>
  <% end %>

  <%= f.submit "Clone set", class: "btn btn-primary mt-3" %>
<% end %>
