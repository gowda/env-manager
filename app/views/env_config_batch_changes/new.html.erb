<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h3 mb-0">Batch Changes</h1>
  <%= link_to "Back", app_app_env_env_config_path(@app, @app_env, @env_config), class: "btn btn-outline-secondary" %>
</div>

<% if @errors.any? %>
  <div class="alert alert-danger">
    <ul class="mb-0">
      <% @errors.each do |error| %>
        <li><%= error %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with url: app_app_env_env_config_batch_changes_path(@app, @app_env, @env_config), method: :post do |f| %>
  <div class="mb-3">
    <%= f.label :input, "Batch Input", class: "form-label" %>
    <%= f.text_area :input, name: "batch[input]", value: @batch_input, rows: 12, class: "form-control", placeholder: "KEY=value\nKEY|multi_line=value\ndelete KEY\n-KEY" %>
  </div>

  <div class="mb-3">
    <%= f.label :reason, "Reason", class: "form-label" %>
    <%= f.text_area :reason, name: "batch[reason]", value: @reason, rows: 3, class: "form-control" %>
  </div>

  <div class="d-flex gap-2 mb-4">
    <%= f.submit "Preview", name: "preview", value: "true", class: "btn btn-outline-primary" %>
    <%= f.submit "Apply", class: "btn btn-primary" %>
  </div>
<% end %>

<% if @preview_items.present? %>
  <h2 class="h5">Preview</h2>
  <div class="table-responsive">
    <table class="table table-sm table-bordered align-middle">
      <thead>
        <tr>
          <th>Line</th>
          <th>Key</th>
          <th>Operation</th>
          <th>From Type</th>
          <th>To Type</th>
          <th>Actionable</th>
        </tr>
      </thead>
      <tbody>
        <% @preview_items.each do |item| %>
          <tr>
            <td><%= item[:line_no] %></td>
            <td><%= item[:key] %></td>
            <td><%= item[:operation] %></td>
            <td><%= item[:previous_value_type] || "-" %></td>
            <td><%= item[:new_value_type] || "-" %></td>
            <td><%= item[:actionable] ? "yes" : "no" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
