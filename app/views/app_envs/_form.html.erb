<%= form_with model: [app, app_env] do |f| %>
  <div class="mb-3">
    <%= f.label :name, class: "form-label" %>
    <%= f.text_field :name, class: "form-control", placeholder: "develop" %>
    <small class="text-body-secondary">Use lowercase letters, numbers, and hyphen only (for example: <code>staging-us</code>).</small>
  </div>

  <%= f.submit class: "btn btn-primary" %>
<% end %>
