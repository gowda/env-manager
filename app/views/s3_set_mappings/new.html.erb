<h1 class="h3 mb-3">New S3 Mapping</h1>

<%= form_with model: [@app, @app_env, @env_set, @mapping] do |f| %>
  <div class="mb-3">
    <%= f.label :match_kind, class: "form-label" %>
    <%= f.select :match_kind, S3SetMapping::MATCH_KINDS, {}, class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= f.label :key_pattern, class: "form-label" %>
    <%= f.text_field :key_pattern, class: "form-control" %>
    <small class="text-body-secondary">Use full object key for exact match, or prefix path ending with <code>/</code> for prefix match.</small>
  </div>

  <div class="mb-3">
    <%= f.label :outbound_identifier, class: "form-label" %>
    <%= f.text_field :outbound_identifier, class: "form-control" %>
    <small class="text-body-secondary">Required for prefix mappings. Outbound key becomes <code>&lt;prefix&gt;/&lt;identifier&gt;.env</code>.</small>
    <br>
    <small class="text-body-secondary">Cleanup on set delete removes only this canonical outbound file per mapping (not recursive prefix cleanup of historical objects).</small>
  </div>

  <div class="form-check mb-3">
    <%= f.check_box :sync_enabled, class: "form-check-input" %>
    <%= f.label :sync_enabled, class: "form-check-label" %>
  </div>

  <%= f.submit class: "btn btn-primary" %>
<% end %>
