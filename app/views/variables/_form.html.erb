<%= form_with model: variable do |f| %>
  <div class="mb-3">
    <%= f.label :key, class: 'form-label' %>
    <%= f.text_field :key, class: 'form-control' %>
  </div>

  <div class="mb-3">
    <%= f.label :type, class: 'form-label' %>
    <%= f.select :type, Variable.types.keys, {}, class: 'form-select' %>
  </div>

  <div class="mb-3">
    <%= f.label :value, class: 'form-label' %>
    <%= f.text_area :value, rows: 4, class: 'form-control auto-expand' %>
  </div>

  <%= f.submit class: 'btn btn-primary' %>
<% end %>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const textareas = document.querySelectorAll('.auto-expand');
    textareas.forEach(textarea => {
      textarea.addEventListener('input', function() {
        this.style.height = 'auto';
        this.style.height = (this.scrollHeight) + 'px';
      });
    });
  });
</script>
