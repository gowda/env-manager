<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h3 mb-0"><%= @app.name %> / <%= @app_env.name %> / <%= @env_config.kind %></h1>
  <div class="d-flex gap-2">
    <%= link_to "Edit", edit_app_app_env_env_config_path(@app, @app_env, @env_config), class: "btn btn-outline-primary" %>
    <%= link_to "Delete", app_app_env_env_config_path(@app, @app_env, @env_config), data: { turbo_method: :delete, turbo_confirm: "Delete this environment config?" }, class: "btn btn-outline-danger" %>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <h2 class="h6">Metadata</h2>
    <pre class="mb-0"><%= JSON.pretty_generate(@env_config.metadata || {}) %></pre>
  </div>
</div>

<div class="d-flex justify-content-between align-items-center mt-4 mb-3">
  <h2 class="h5 mb-0">Environment Variables</h2>
  <%= link_to "Add Environment Variable", new_app_app_env_env_config_environment_variable_path(@app, @app_env, @env_config), class: "btn btn-primary" %>
</div>

<div class="list-group">
  <% @env_config.environment_variables.order(:key).each do |environment_variable| %>
    <%= link_to environment_variable.key, app_app_env_env_config_environment_variable_path(@app, @app_env, @env_config, environment_variable), class: "list-group-item list-group-item-action" %>
  <% end %>
</div>
