<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h3 mb-0"><%= @environment_variable.key %></h1>
  <div class="d-flex gap-2">
    <%= link_to "Edit", edit_app_app_env_env_config_environment_variable_path(@app, @app_env, @env_config, @environment_variable), class: "btn btn-outline-primary" %>
    <%= link_to "Delete", app_app_env_env_config_environment_variable_path(@app, @app_env, @env_config, @environment_variable), data: { turbo_method: :delete, turbo_confirm: "Delete this environment variable?" }, class: "btn btn-outline-danger" %>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <p class="mb-2"><strong>Value Type:</strong> <%= @environment_variable.value_type %></p>
    <% if @environment_variable.value_type == "secret" %>
      <p class="mb-0"><strong>Value:</strong> ••••••••</p>
    <% else %>
      <h2 class="h6">Value</h2>
      <pre class="mb-0"><%= @environment_variable.value %></pre>
    <% end %>
  </div>
</div>
