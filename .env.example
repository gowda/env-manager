# Rails runtime
RAILS_ENV=development
RAILS_LOG_LEVEL=info
FORCE_SSL=false

# Application secrets (required)
SECRET_KEY_BASE=replace_with_secure_secret_key_base
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=replace_with_secure_primary_key
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=replace_with_secure_deterministic_key
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=replace_with_secure_key_derivation_salt

# Database
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=env_manager_development

# Integrations
AWS_REGION=us-east-1
GITHUB_TOKEN=replace_with_github_token
S3_ENV_IMPORT_BUCKET=replace_with_bucket_name
S3_ENV_SYNC_SQS_QUEUE_URL=

# Runtime tuning
RAILS_MAX_THREADS=5
JOB_CONCURRENCY=1
